# ── Metis Client Hub — environment ─────────────────────────────────────────
# Copy to .env.local and fill in. The app runs fully in "demo mode" with none
# of these set; each key flips the corresponding feature from stub → live.

# ── Auth (Clerk) ────────────────────────────────────────────────────────────
# When set, the app uses Clerk for real SSO restricted to @metisstrategy.com.
# When empty, the app uses the built-in demo sign-in (email-gated, no password).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Web scraping / research (LLM) ────────────────────────────────────────────
# Powers scripts/scrape.mjs to refresh the weekly Client Pulse from live news.
ANTHROPIC_API_KEY=
# Optional dedicated web-search key if you use one (e.g. Tavily, Serper)
SEARCH_API_KEY=

# ── Transactional email (weekly newsletter) ──────────────────────────────────
# Provider for the weekly Monday 7am ET send. Resend shown; swap as needed.
RESEND_API_KEY=
EMAIL_FROM="Metis Client Pulse <pulse@metisstrategy.com>"

# ── Podcast (ElevenLabs) ──────────────────────────────────────────────────────
# When set, /api/podcast generates real audio; otherwise returns the demo track.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_HOST=
ELEVENLABS_VOICE_GUEST=

# ── Cron secret ──────────────────────────────────────────────────────────────
# Vercel Cron / GitHub Action passes this to authorize /api/cron/weekly.
CRON_SECRET=
