# ── Metis Client Hub — environment ─────────────────────────────────────────
# Copy to .env.local and fill in. The app runs fully in "demo mode" with none
# of these set; each key flips the corresponding feature from stub → live.

# ── Auth (Clerk) ────────────────────────────────────────────────────────────
# When set, the app uses Clerk for real SSO restricted to @metisstrategy.com.
# When empty, the app uses the built-in demo sign-in (email-gated, no password).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Web scraping / research (LLM) ────────────────────────────────────────────
# Powers scripts/scrape.mjs to refresh the weekly Client Pulse from live news.
ANTHROPIC_API_KEY=
# Optional dedicated web-search key if you use one (e.g. Tavily, Serper)
SEARCH_API_KEY=

# ── Transactional email (weekly newsletter) ──────────────────────────────────
# Provider for the weekly send. Resend shown; swap in lib/email.js as needed.
# With no key, sends are "stubbed" (rendered + logged, nothing delivered).
RESEND_API_KEY=
EMAIL_FROM="Metis Client Pulse <pulse@metisstrategy.com>"

# ── Subscriber store (who gets emailed) ──────────────────────────────────────
# Upstash Redis (REST) persists subscribers across serverless invocations.
# Create a free DB at upstash.com and paste the REST URL + token. Without these,
# the app uses a local .data/subscribers.json file (fine for `npm run dev`,
# not for serverless).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Podcast (ElevenLabs) ──────────────────────────────────────────────────────
# When set, /api/podcast generates real audio; otherwise returns the demo track.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_HOST=
ELEVENLABS_VOICE_GUEST=

# ── Cron secret ──────────────────────────────────────────────────────────────
# Set this and Vercel Cron automatically sends it as a Bearer token to authorize
# /api/cron/weekly. The daily schedule lives in vercel.json (07:00 ET); each user
# is emailed only on the delivery day they picked in Settings.
CRON_SECRET=

# ── App URL ──────────────────────────────────────────────────────────────────
# Absolute base URL of the deployed app, used to build unsubscribe/manage links
# in the emails (e.g. https://client-hub.metisstrategy.com).
NEXT_PUBLIC_APP_URL=
